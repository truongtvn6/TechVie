# ===================================================
# .env.example — Template cấu hình môi trường Backend
# Copy file này thành .env.local để chạy local
# ===================================================

# ===== CẤU HÌNH SERVER =====
PORT=5000
NODE_ENV=development

# ===== CẤU HÌNH DATABASE =====
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/techvie?appName=<appname>

# ===== CẤU HÌNH JWT =====
JWT_SECRET=techvie_jwt_secret_key_2026_change_this_in_production

# ===== CẤU HÌNH CLOUDINARY =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== CẤU HÌNH GOOGLE OAUTH2 =====
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Local:
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# Production (Render):
# GOOGLE_REDIRECT_URI=https://techvie-backend.onrender.com/api/auth/google/callback

# ===== CẤU HÌNH EMAIL (NODEMAILER) =====
# Dùng Gmail App Password (không phải mật khẩu tài khoản)
EMAIL_SERVICE=gmail
EMAIL_USER=noreply.techvie@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ===== URL FRONTEND =====
# Local:
FRONTEND_URL=http://localhost:3000
# Production (Vercel):
# FRONTEND_URL=https://techvie.vercel.app
