# ===== CẤU HÌNH SERVER =====
PORT=5000
API_BASE_URL=http://localhost:5000

# ===== CẤU HÌNH DATABASE =====
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/techvie

# ===== CẤU HÌNH JWT =====
JWT_SECRET=techvie_jwt_secret_key_2026

# ===== CẤU HÌNH CLOUDINARY =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== CẤU HÌNH GOOGLE OAUTH2 =====
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ===== CẤU HÌNH EMAIL (NODEMAILER) =====
# Sử dụng Gmail: Bật "Quyền truy cập ứng dụng kém an toàn" hoặc dùng App Password
EMAIL_SERVICE=gmail
EMAIL_USER=noreply.techvie@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx   # App Password 16 ký tự của Google

# ===== URL FRONTEND =====
# Dùng để tạo link reset password trong email
FRONTEND_URL=http://localhost:3000
